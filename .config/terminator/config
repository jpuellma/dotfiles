[global_config]
  always_split_with_profile = True
  borderless = True
  broadcast_default = off
  custom_url_handler = vivaldi-snapshot
  dbus = True
  enabled_plugins = CustomCommandsMenu, InactivityWatch, ActivityWatch, TerminalShot, LaunchpadCodeURLHandler, APTURLHandler, Logger
  focus = mouse
  geometry_hinting = False
  handle_size = 3
  homogeneous_tabbar = False
  inactive_color_offset = 0.89
  scroll_tabbar = True
  suppress_multiple_term_dialog = True
  tab_position = bottom
  title_inactive_bg_color = "#565656"
  title_inactive_fg_color = "#ffffff"
  title_receive_bg_color = "#579baf"
  title_receive_fg_color = "#424242"
  title_transmit_bg_color = "#0087af"
  use_custom_url_handler = True
[keybindings]
  broadcast_all = <Primary><Shift>a
  broadcast_group = <Primary><Shift>g
  broadcast_off = <Primary><Shift>n
  full_screen = None
  go_down = <Primary><Shift>j
  go_left = <Primary><Shift>h
  go_next = None
  go_prev = None
  go_right = <Primary><Shift>l
  go_up = <Primary><Shift>k
  hide_window = None
  reset_clear = None
  ungroup_tab = None
  zoom_in = <Primary><Shift>plus
  zoom_normal = <Super>0
  zoom_out = <Primary><Shift>underscore
[layouts]
  [[default]]
    [[[child1]]]
      parent = window0
      type = Terminal
    [[[window0]]]
      parent = ""
      type = Window
[plugins]
  [[CustomCommandsMenu]]
    [[[alias pat]]]
      command = '''/bin/grep -q "alias pat=" ~/.bash_profile || echo "alias pat='puppet agent -t 2>&1 | tee ~/pat.out'" >> ~/.bash_profile && . ~/.bash_profile'''
      enabled = True
      name = alias pat
      position = 0
    [[[alias patd]]]
      command = '''/bin/grep -q "alias patd=" ~/.bash_profile || echo "alias patd='puppet agent -t --debug 2>&1 | tee ~/pat.out'" >> ~/.bash_profile && . ~/.bash_profile'''
      enabled = True
      name = alias patd
      position = 1
    [[[settitle]]]
      command = '''printf "\033k$(hostname -f)\033"
'''
      enabled = True
      name = settitle
      position = 2
